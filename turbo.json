{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalPassThroughEnv": [
    "API_PORT",
    "DATABASE_URL",
    "NEXT_PUBLIC_API_BASE_URL",
    "SERVIER_ASSISTANT_ENABLED",
    "SERVIER_AI_PROVIDER",
    "SERVIER_CODEX_PROVIDER",
    "OPENAI_API_KEY",
    "OPENAI_MODEL",
    "WEB_ORIGIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "packages/db/prisma/schema.prisma", "packages/db/prisma/migrations/**"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
